rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /shipments/{shipmentId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null;
    }

    match /leads/{leadId} {
      allow read, create, update, delete: if request.auth != null;
    }
  }
}
