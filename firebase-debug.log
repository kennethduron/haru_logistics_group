[debug] [2026-05-07T14:49:51.353Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/kennethlogisticsgroup/rulesets {"name":"projects/kennethlogisticsgroup/rulesets/f87a698d-86ed-4266-8300-ab174d281bbf","source":{"files":[{"content":"rules_version = '2';\n\nservice cloud.firestore {\n  match /databases/{database}/documents {\n    match /shipments/{shipmentId} {\n      allow read: if true;\n      allow create, update, delete: if request.auth != null;\n    }\n\n    match /leads/{leadId} {\n      allow read, update, delete: if request.auth != null;\n      allow create: if isValidLead();\n    }\n  }\n\n  function isValidLead() {\n    return request.resource.data.keys().hasOnly([\n        \"id\",\n        \"name\",\n        \"company\",\n        \"email\",\n        \"phone\",\n        \"origin\",\n        \"destination\",\n        \"service\",\n        \"rep\",\n        \"status\",\n        \"notes\",\n        \"createdAt\"\n      ])\n      && request.resource.data.id is string\n      && request.resource.data.id.size() <= 80\n      && request.resource.data.name is string\n      && request.resource.data.name.size() >= 1\n      && request.resource.data.name.size() <= 120\n      && request.resource.data.company is string\n      && request.resource.data.company.size() <= 120\n      && request.resource.data.email is string\n      && request.resource.data.email.size() >= 3\n      && request.resource.data.email.size() <= 160\n      && request.resource.data.phone is string\n      && request.resource.data.phone.size() >= 3\n      && request.resource.data.phone.size() <= 60\n      && request.resource.data.origin is string\n      && request.resource.data.origin.size() <= 160\n      && request.resource.data.destination is string\n      && request.resource.data.destination.size() <= 160\n      && request.resource.data[\"service\"] is string\n      && request.resource.data[\"service\"].size() <= 80\n      && request.resource.data.rep is string\n      && request.resource.data.rep.size() <= 120\n      && request.resource.data.status == \"lead\"\n      && request.resource.data.notes is string\n      && request.resource.data.notes.size() <= 1200\n      && request.resource.data.createdAt is string\n      && request.resource.data.createdAt.size() <= 20;\n  }\n}\n","name":"firestore.rules"}]},"createTime":"2026-05-07T14:49:50.389855Z","metadata":{"services":["cloud.firestore"]}}
